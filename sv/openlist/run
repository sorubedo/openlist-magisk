#!/system/bin/sh
exec 2>&1

[ -r ./conf ] && set -a && . ./conf && set +a

if [ "${WAIT_DECRYPT:-0}" != "0" ]; then
    echo "🔄 检测存储解密状态..."
    if [ ! -d /storage/emulated/0/Android ] || [ ! -r /storage/emulated/0/Android ]; then
        echo "🔐 存储未解密，等待 30s 后退出服务..."
        sleep 30
        exit 1
    fi
    echo "✅ OK"
fi

exec chpst -u "${CHPST_USER:-shell:inet:sdcard_r:sdcard_rw}" \
    openlist server ${OPENLIST_ARGS:---data /storage/emulated/0/Android/openlist}
